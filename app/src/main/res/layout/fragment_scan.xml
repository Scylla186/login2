<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Vista de cámara en tiempo real -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay oscuro con recorte central tipo visor -->
    <View
        android:id="@+id/scan_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scan_overlay"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Marco del visor QR -->
    <View
        android:id="@+id/scan_frame"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/scan_frame"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Logo OpticHelp temporal sobre el visor -->
    <TextView
        android:id="@+id/tv_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OpticHelp"
        android:textColor="#1A73E8"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="56dp"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hint accesible — TalkBack lo lee al entrar al fragment -->
    <TextView
        android:id="@+id/tv_scan_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scan_hint"
        android:textColor="#CCFFFFFF"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="120dp"
        android:contentDescription="@string/scan_hint_cd"
        android:importantForAccessibility="yes"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Área de toque invisible — accesible para TalkBack -->
    <View
        android:id="@+id/touch_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/scan_hint_cd"
        android:importantForAccessibility="yes"
        android:focusable="true"
        android:clickable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Feedback de QR inválido -->
    <TextView
        android:id="@+id/tv_invalid_qr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scan_invalid_qr"
        android:textColor="#FF5252"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        android:background="#CC000000"
        android:visibility="gone"
        android:importantForAccessibility="yes"
        android:layout_marginBottom="180dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>